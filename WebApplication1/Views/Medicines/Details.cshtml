@model WebApplication1.Models.Medicine

@{
    ViewBag.Title = "Details";
}

<div class="container mt-4">

    <h2 class="text-center fw-bold">Medicine Details 💊</h2>

    <div class="card shadow-lg p-4 mt-3">

        <dl class="row">

            <dt class="col-sm-3">Medicine Name</dt>
            <dd class="col-sm-9">@Model.MedicineName</dd>

            <!-- ✅ ADDED THIS (IMPORTANT) -->
            <dt class="col-sm-3">Company</dt>
            <dd class="col-sm-9">@Model.MedicineCompany</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">@Model.Stock</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">₹ @Model.Price</dd>

            <dt class="col-sm-3">Available</dt>
            <dd class="col-sm-9">
                @if (Model.Available)
                {
                    <span class="badge bg-success">Yes</span>
                }
                else
                {
                    <span class="badge bg-danger">No</span>
                }
            </dd>

            <dt class="col-sm-3">Pharmacy ID</dt>
            <dd class="col-sm-9">@Model.PharmacyId</dd>

        </dl>

        <div class="text-center mt-3">
            <a href="@Url.Action("Edit", new { id = Model.MedicineId })"
               class="btn btn-warning me-2">
                Edit
            </a>

            <a href="@Url.Action("Index")"
               class="btn btn-secondary">
                Back to List
            </a>
        </div>

    </div>

</div>