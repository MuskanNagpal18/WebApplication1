\@model WebApplication1.Models.Medicine

@{
    ViewBag.Title = "Create Medicine";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h2 class="mb-4 fw-bold">Add New Medicine</h2>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="mb-3">
                    @Html.LabelFor(model => model.MedicineName, new { @class = "form-label" })
                    @Html.TextBoxFor(model => model.MedicineName, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.MedicineName, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(model => model.MedicineCompany, new { @class = "form-label" })
                    @Html.TextBoxFor(model => model.MedicineCompany, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.MedicineCompany, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(model => model.Stock, new { @class = "form-label" })
                    @Html.TextBoxFor(model => model.Stock, new { @class = "form-control", type = "number" })
                    @Html.ValidationMessageFor(model => model.Stock, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(model => model.Price, new { @class = "form-label" })
                    @Html.TextBoxFor(model => model.Price, new { @class = "form-control", type = "number", step = "0.01" })
                    @Html.ValidationMessageFor(model => model.Price, "", new { @class = "text-danger" })
                </div>

                <div class="form-check mb-3">
                    @Html.CheckBoxFor(model => model.Available, new { @class = "form-check-input" })
                    @Html.LabelFor(model => model.Available, new { @class = "form-check-label" })
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-save"></i> Save
                </button>

                <a href="@Url.Action("Index")" class="btn btn-secondary ms-2">
                    Cancel
                </a>
            }

        </div>
    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}