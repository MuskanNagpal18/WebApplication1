<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Medicine Management System</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <a class="navbar-brand" href="@Url.Action("Index", "Home")">
            Medicine Management System
        </a>

        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mr-auto">

                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "Home")">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("About", "Home")">About</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Contact", "Home")">Contact</a>
                </li>

                @if (Session["UserId"] != null)
                {
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Dashboard", "Home")">Dashboard</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Users")">Users</a>
                    </li>
                }

            </ul>

            <ul class="navbar-nav">
                @if (Session["UserId"] == null)
                {
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Login", "Users")">Login</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Register", "Users")">Register</a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <span class="navbar-text text-white mr-3">
                            Welcome, @Session["UserName"]
                        </span>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Logout", "Users")">Logout</a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <hr />
    <footer class="text-center mb-3">
        <p>© @DateTime.Now.Year - Medicine Management System</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
