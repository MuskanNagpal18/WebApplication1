@model IEnumerable<WebApplication1.Models.User>

@{
    ViewBag.Title = "Users";
}

<div class="container mt-4">

    <!-- Title -->
    <div class="text-center mb-3">
        <h2 class="fw-bold fst-italic">Users Management</h2>
    </div>

    <!-- Create Button -->
    <div class="text-center mb-4">
        <a href="@Url.Action("Create")"
           class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus"></i> Create New
        </a>
    </div>

    <!-- Search + Filter -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row justify-content-center">

                <!-- Search -->
                <div class="col-md-5">
                    <input type="text"
                           name="search"
                           value="@Request["search"]"
                           class="form-control"
                           placeholder="Search by name or email..." />
                </div>

                <!-- Role Filter -->
                <div class="col-md-3">
                    <select name="role" class="form-select">
                        <option value="">All Roles</option>
                        <option value="Admin" @(Request["role"] == "Admin" ? "selected" : "")>Admin</option>
                        <option value="User" @(Request["role"] == "User" ? "selected" : "")>User</option>
                    </select>
                </div>

                <!-- Button -->
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fa-solid fa-magnifying-glass"></i> Search
                    </button>
                </div>

            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">

            <table class="table table-bordered table-hover align-middle text-center">

                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-muted">
                                No users found
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Email</td>

                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge rounded-pill bg-danger px-3 py-2">
                                            Admin
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-success px-3 py-2">
                                            User
                                        </span>
                                    }
                                </td>

                                <td>
                                    <a href="@Url.Action("Edit", new { id = item.UserId })"
                                       class="btn btn-sm btn-warning me-1">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>

                                    <a href="@Url.Action("Details", new { id = item.UserId })"
                                       class="btn btn-sm btn-info me-1">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>

                                    <a href="@Url.Action("Delete", new { id = item.UserId })"
                                       class="btn btn-sm btn-danger">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>