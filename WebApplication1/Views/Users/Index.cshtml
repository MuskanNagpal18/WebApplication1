@model IEnumerable<WebApplication1.Models.User>

@{
    ViewBag.Title = "Users";
}

<h2 class="mb-3">Users List</h2>

<p>
    @Html.ActionLink("➕ Create New User", "Create", null, new { @class = "btn btn-primary" })
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No users found.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead class="thead-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Password</th>
                <th>Role</th>
                <th style="width:180px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.PasswordHash</td>
                    <td>@item.Role</td>
                    <td>
                        @Html.ActionLink("Edit", "Edit", new { id = item.UserId }, new { @class = "btn btn-sm btn-warning" })
                        @Html.ActionLink("Details", "Details", new { id = item.UserId }, new { @class = "btn btn-sm btn-info ml-1" })
                        @Html.ActionLink("Delete", "Delete", new { id = item.UserId }, new { @class = "btn btn-sm btn-danger ml-1" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
