@{
        ViewBag.Title = "Login";
}

<h2>Login</h2>

@if (ViewBag.Error!= null)
{
<div style="color:red">
    @ViewBag.Error
</div>
}

@using (Html.BeginForm())
{
<div>
    <label>Email</label>
    <br />
    <input type="text" name="email" required />
</div>

<div>
    <label>Password</label>
    <br />
    <input type="password" name="password" required />
</div>

<br />
<button type="submit">Login</button>
}