@{
    ViewBag.Title = "Privacy Policy";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">Privacy Policy</h1>
        <p class="text-muted">
            Your privacy and data security are our top priority.
        </p>
    </div>

    <div class="row">

        <!-- Data Protection -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm p-4 h-100">
                <i class="fa-solid fa-shield-halved fa-2x text-primary mb-3"></i>
                <h5>Data Protection</h5>
                <p class="text-muted">
                    The Medicine Management System ensures that all personal
                    and medical information is securely stored and protected.
                </p>
            </div>
        </div>

        <!-- No Third Party Sharing -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm p-4 h-100">
                <i class="fa-solid fa-user-secret fa-2x text-success mb-3"></i>
                <h5>No Third-Party Sharing</h5>
                <p class="text-muted">
                    This application does not share user data with third parties.
                    It is intended for educational and administrative use only.
                </p>
            </div>
        </div>

    </div>

    <div class="text-center mt-4">
        <small class="text-muted">
            © 2026 - Medicine Management System
        </small>
    </div>

</div>