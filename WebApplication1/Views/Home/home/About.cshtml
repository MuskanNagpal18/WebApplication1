@{
    ViewBag.Title = "About";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">About the System</h1>
        <p class="text-muted">
            Smart solution for medicine tracking and pharmacy management.
        </p>
    </div>

    <div class="card shadow-sm p-4">
        <p>
            The Medicine Tracker & Online Pharmacy System is designed to help users
            manage their daily medicines efficiently. It allows users to add,
            edit, and monitor medicines along with reminder times and stock levels.
        </p>

        <p>
            The system also includes an administrative module where the admin can
            manage users, monitor low stock alerts, and maintain medicine inventory.
        </p>

        <p>
            This project is developed using ASP.NET MVC and follows a structured
            Model-View-Controller architecture for better maintainability and scalability.
        </p>
    </div>

    <div class="text-center mt-4">
        <small class="text-muted">
            © 2026 - Medicine Management System
        </small>
    </div>

</div>