@{
    ViewBag.Title = "Administrator Information";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">Administrator Information</h1>
        <p class="text-muted">
            System control and management access.
        </p>
    </div>

    <div class="row">

        <!-- System Management -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm p-4 h-100">
                <i class="fa-solid fa-user-shield fa-2x text-danger mb-3"></i>
                <h5>System Management</h5>
                <p class="text-muted">
                    The administrator ensures proper handling of medicines,
                    stock availability, and user management.
                </p>
            </div>
        </div>

        <!-- Full Access Control -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm p-4 h-100">
                <i class="fa-solid fa-chart-column fa-2x text-primary mb-3"></i>
                <h5>Full Access Control</h5>
                <p class="text-muted">
                    Admin has full access to manage users, medicines,
                    and monitor low stock alerts via dashboard.
                </p>
            </div>
        </div>

    </div>

    <div class="text-center mt-4">
        <small class="text-muted">
            © 2026 - Medicine Management System
        </small>
    </div>

</div>


