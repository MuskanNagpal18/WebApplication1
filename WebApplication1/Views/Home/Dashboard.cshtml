@{
    ViewBag.Title = "Admin Dashboard";
}

<h2 class="mb-4">Admin Dashboard</h2>

<div class="row">

    <div class="col-md-4">
        <div class="card text-white bg-primary mb-4">
            <div class="card-body">
                <h4>Total Users</h4>
                <h2>@ViewBag.TotalUsers</h2>
            </div>
            <div class="card-footer text-center">
                <a href="/Users" class="text-white">Manage Users</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success mb-4">
            <div class="card-body">
                <h4>Total Medicines</h4>
                <h2>@ViewBag.TotalMedicines</h2>
            </div>
            <div class="card-footer text-center">
                <a href="/Medicines" class="text-white">Manage Medicines</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-danger mb-4">
            <div class="card-body">
                <h4>Low Stock Items</h4>
                <h2>@ViewBag.LowStock</h2>
                <small>Stock less than 10</small>
            </div>
        </div>
    </div>

</div>