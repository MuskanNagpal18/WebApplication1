@{
    ViewBag.Title = "Services";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Our Services</h1>
        <p class="text-muted">
            We provide smart medicine management and pharmacy solutions.
        </p>
    </div>

    <div class="row">

        <!-- Medicine Tracking -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 text-center p-4">
                <i class="fa-solid fa-pills fa-3x text-success mb-3"></i>
                <h4>Medicine Tracking</h4>
                <p class="text-muted">
                    Track daily medicines, reminders, and dosage schedules easily.
                </p>
            </div>
        </div>

        <!-- Inventory Management -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 text-center p-4">
                <i class="fa-solid fa-boxes-stacked fa-3x text-primary mb-3"></i>
                <h4>Inventory Management</h4>
                <p class="text-muted">
                    Manage stock levels, monitor low inventory, and update quantities.
                </p>
            </div>
        </div>

        <!-- Online Pharmacy -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 text-center p-4">
                <i class="fa-solid fa-cart-shopping fa-3x text-danger mb-3"></i>
                <h4>Online Pharmacy</h4>
                <p class="text-muted">
                    Browse available medicines and view stock availability.
                </p>
            </div>
        </div>

    </div>
</div>